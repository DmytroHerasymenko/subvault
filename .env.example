# Supabase (free tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL for OAuth (must match the URL users open in the browser)
# Local:     http://localhost:3000
# Production (free): https://renulo.vercel.app
# Later:     https://renulo.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — only for scripts/configure-supabase-smtp.mjs (never commit real values)
# SUPABASE_ACCESS_TOKEN=your-personal-access-token
# SUPABASE_PROJECT_REF=your-project-ref
# SMTP_PROVIDER=resend
# RESEND_API_KEY=re_...
# SMTP_FROM_EMAIL=no-reply@renulo.app
# SMTP_SENDER_NAME=Renulo
# SMTP_RATE_LIMIT_EMAIL_SENT=100
# Gmail interim (until renulo.app domain on Resend):
# SMTP_PROVIDER=gmail
# SMTP_FROM_EMAIL=renulo.app@gmail.com
# GMAIL_APP_PASSWORD=your-google-app-password
